# ── Application ────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Vesion
API_PORT=4000
WEB_PORT=3000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
# Comma-separated list of origins allowed by CORS
CORS_ORIGINS=http://localhost:3000

# ── Database ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=version
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=version
DATABASE_URL=postgresql://version:change-me-strong-password@localhost:5432/version?schema=public

# ── Redis (cache, queues, rate limiting) ───────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth / Security ────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-base64-48
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
# 32-byte hex key for AES-256-GCM encryption of 2FA secrets: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
COOKIE_SECRET=replace-with-openssl-rand-base64-48
# Bcrypt cost factor
BCRYPT_ROUNDS=12

# ── Rate limiting ──────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── SMTP (transactional email — your own mail server) ─────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Vesion <no-reply@vesion.dev>"

# ── File storage (local disk) ──────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25

# ── Frontend (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
